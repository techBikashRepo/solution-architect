      "label": "Cache-Aside",
      "icon": "🔄",
      "type": "leaf",
      "parent": "strategies",
      "items": [
        "App manages cache manually",
        "Read-miss → load from DB → store in cache",
        "Most common pattern (Redis)"
      ]
    },
    {
      "id": "eviction",
      "label": "Eviction Policies",
      "icon": "🗑️",
      "type": "branch",
      "parent": "root",
      "badge": "When Full",
      "color": "#10b981",
      "description": "Which items get removed when cache is full"
    },
    {
      "id": "lru",
      "label": "LRU",
      "icon": "⏪",
      "type": "leaf",
      "parent": "eviction",
      "items": [
        "Least Recently Used",
        "Evict item not accessed for longest time",
        "Default in Redis"
      ]
    },
    {
      "id": "lfu",
      "label": "LFU",
      "icon": "📊",
      "type": "leaf",
      "parent": "eviction",
      "items": [
        "Least Frequently Used",
        "Evict item accessed fewest times",
        "Better for skewed access"
      ]
    },
    {
      "id": "ttl",
      "label": "TTL",
      "icon": "⏱️",
      "type": "leaf",
      "parent": "eviction",
      "items": [
        "Time-To-Live expiry",
        "Each entry has max age",
        "Prevents stale data accumulation",
        "Redis: SET key value EX 3600"
      ]
    },
    {
      "id": "pitfalls",
      "label": "Cache Pitfalls",
      "icon": "⚠️",
      "type": "branch",
      "parent": "root",
      "badge": "Failure Modes",
      "color": "#f43f5e",
      "description": "Common caching failures to prevent"
    },
    {
      "id": "cache-stampede",
      "label": "Cache Stampede",
      "icon": "🐘",
      "type": "leaf",
      "parent": "pitfalls",
      "items": [
        "Mass cache expiry at same time → DB overwhelmed",
        "Fix: jitter on TTL (TTL ± random 10%)",
        "Fix: probabilistic early recompute (PER)",
        "Fix: mutex lock to let one request populate"
      ]
    },
    {
      "id": "cache-penetration",
      "label": "Cache Penetration",
      "icon": "🕳️",
      "type": "leaf",
      "parent": "pitfalls",
      "items": [
        "Queries for non-existent keys bypass cache",
        "Fix: cache null/empty results with short TTL",
        "Fix: Bloom Filter to pre-check existence",
        "Attack vector: spam random non-existent IDs"
      ]
    },
    {
      "id": "read-through",
      "label": "Read-Through",
      "icon": "📖",
      "type": "leaf",
      "parent": "pitfalls",
      "items": [
        "Cache sits in front of DB transparently",
        "Cache handles miss → fetches from DB itself",
        "App always talks to cache only",
        "Used in: ElastiCache + RDS pattern"
      ]
    }
  ]
